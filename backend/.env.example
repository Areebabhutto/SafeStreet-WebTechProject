# --- Server ---
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL + PostGIS) ---
DATABASE_URL=postgresql://safestreet:safestreet_pw@localhost:5432/safestreet?schema=public

# --- Redis (socket.io adapter for horizontal scaling) ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRY=7d

# --- Google Gemini ---
# NEVER hardcode this key in source. Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AQ.Ab8RN6KyfU1G8UCiqJsoj136q1tJh3Ui7GX0qnsGy1KS45kR6Q
# Model name is read from env so it can be swapped without a code change,
# e.g. to a newer "gemini-flash" alias as Google ships new versions.
GEMINI_MODEL=gemini-flash-latest

# --- SLA ---
# Minutes-to-deadline overrides per priority (comma-separated CRITICAL,HIGH,MEDIUM,LOW)
SLA_MINUTES_CRITICAL=60
SLA_MINUTES_HIGH=240
SLA_MINUTES_MEDIUM=1440
SLA_MINUTES_LOW=4320
