// =============================================================================
// SafeStreet — Prisma Schema
// PostgreSQL 15. Geospatial data is stored as indexed Decimal(9,6) lat/lng
// columns, which the AI Duplicate Detector queries with a cheap bounding-box
// WHERE filter followed by exact Haversine math in the service layer (see
// ai-proxy/utils/geo.util.ts). The docker-compose Postgres image ships with
// PostGIS available, so this can be upgraded to a native
// `geometry(Point,4326)` column + ST_DWithin later without changing the
// application's public interface.
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  // "native" covers your host machine (for local npm run without Docker).
  // "linux-musl-openssl-3.0.x" covers the node:20-alpine container, which
  // uses musl libc + OpenSSL 3.x (see backend/Dockerfile's apk add openssl).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------

enum Role {
  CITIZEN
  WORKER
  SUPERVISOR
  ADMIN
}

/// Lifecycle of an incident report. Enforced by IncidentsService's
/// ALLOWED_TRANSITIONS state machine — not just decorative.
enum IncidentStatus {
  SUBMITTED
  TRIAGED
  ASSIGNED
  EN_ROUTE
  ON_SITE
  RESOLVED
  CLOSED
  REJECTED
}

enum IncidentPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Categories the Gemini classifier is constrained to via responseSchema enum
/// in AiProxyService.classifyAndRoute — keep these two in sync.
enum IncidentCategory {
  POTHOLE
  STREETLIGHT
  GARBAGE
  WATER_LEAKAGE
  ILLEGAL_DUMPING
  ROAD_SAFETY
  GRAFFITI
  TREE_HAZARD
  DRAINAGE
  OTHER
}

// -----------------------------------------------------------------------
// CORE MODELS
// -----------------------------------------------------------------------

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  /// Short routing code the AI classifier returns, e.g. "ROADS",
  /// "SANITATION", "WATER", "ELECTRICAL", "PARKS", "PUBLIC_SAFETY", "OTHER".
  /// Plain String (not an enum) so new departments can be added at runtime
  /// via the AdminDash without a schema migration, and so lookups can use
  /// Prisma's case-insensitive `mode: 'insensitive'` string filter.
  code        String     @unique
  description String?
  users       User[]
  incidents   Incident[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  passwordHash String
  fullName String
  phone    String?
  role     Role    @default(CITIZEN)

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  /// Bcrypt hash of the current refresh token, enabling rotation +
  /// server-side revocation (logout invalidates by nulling this out).
  hashedRefreshToken String?
  isActive           Boolean @default(true)

  reportedIncidents Incident[]         @relation("ReportedBy")
  assignedIncidents Incident[]         @relation("AssignedTo")
  timelineEntries   IncidentTimeline[]
  auditLogs         AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([departmentId])
}

model Incident {
  id          String           @id @default(uuid())
  title       String
  description String
  category    IncidentCategory
  priority    IncidentPriority @default(MEDIUM)
  status      IncidentStatus   @default(SUBMITTED)

  // --- Geospatial (see file-level comment re: PostGIS upgrade path) ---
  latitude  Decimal @db.Decimal(9, 6)
  longitude Decimal @db.Decimal(9, 6)
  address   String?

  /// Base64 data-URI or mock storage URL — see file-upload notes in
  /// incidents.controller.ts / CitizenDash.tsx.
  imageUrl String?

  // --- AI metadata (surfaced to users via AIFeedback.tsx) ---
  aiRationale     String? @db.Text
  aiConfidence    Float?
  aiDraftResponse String? @db.Text

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  reportedBy   User   @relation("ReportedBy", fields: [reportedById], references: [id])
  reportedById String

  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId String?

  // --- SLA tracking (see IncidentsService.monitorSlaBreaches cron) ---
  slaDeadline DateTime?
  slaBreached Boolean   @default(false)

  timeline  IncidentTimeline[]
  auditLogs AuditLog[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([status])
  @@index([priority])
  @@index([departmentId])
  @@index([latitude, longitude])
}

/// Append-only audit trail of every status change an incident goes through,
/// rendered as a vertical timeline in the incident detail view.
model IncidentTimeline {
  id         String         @id @default(uuid())
  incident   Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  incidentId String
  actor      User?          @relation(fields: [actorId], references: [id])
  actorId    String?
  status     IncidentStatus
  note       String?        @db.Text
  imageUrl   String?
  createdAt  DateTime       @default(now())

  @@index([incidentId])
}

/// System-wide audit log (logins, AI decisions, assignments, status changes,
/// admin actions) — queryable by ADMIN for compliance/debugging.
model AuditLog {
  id         String    @id @default(uuid())
  actor      User?     @relation(fields: [actorId], references: [id])
  actorId    String?
  action     String // e.g. "LOGIN", "AI_CLASSIFICATION", "ASSIGN", "STATUS_CHANGE"
  incident   Incident? @relation(fields: [incidentId], references: [id])
  incidentId String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([actorId])
  @@index([incidentId])
}
